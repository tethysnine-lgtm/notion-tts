# ── Anthropic (Claude API) ─────────────────────────────────────────
# https://console.anthropic.com/ → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── ElevenLabs (TTS) ───────────────────────────────────────────────
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# (선택) 사용할 음성 ID. 미설정 시 기본 다국어 음성 사용.
# https://elevenlabs.io/app/voice-library 에서 Voice ID 확인
ELEVENLABS_VOICE_ID=
# (선택) TTS 모델. 기본값 eleven_multilingual_v2 (한국어 지원)
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ── Notion ─────────────────────────────────────────────────────────
# https://www.notion.so/my-integrations 에서 Internal Integration 생성
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
